datasource db {
  provider = "sqlite"
  // Wasp requires that the url is set to the DATABASE_URL environment variable.
  url      = env("DATABASE_URL")
}

// Wasp requires the `prisma-client-js` generator to be present.
generator client {
  provider = "prisma-client-js"
}

model User {
    id      Int                 @id @default(autoincrement())
    files   MediaFile[]
    jobs    CompressionJob[]
    presets CompressionPreset[]
}

model MediaFile {
    id           Int              @id @default(autoincrement())
    originalName String
    mimeType     String
    sizeBytes    Int
    storagePath  String
    checksum     String?
    durationSec  Int?
    createdAt    DateTime         @default(now())
    updatedAt    DateTime         @updatedAt
    user         User             @relation(fields: [userId], references: [id])
    userId       Int
    jobsAsInput  CompressionJob[] @relation("JobInput")
    jobsAsOutput CompressionJob[] @relation("JobOutput")
}

model CompressionPreset {
    id                Int              @id @default(autoincrement())
    name              String
    description       String?
    crf               Int?
    targetBitrateKbps Int?
    maxWidth          Int?
    maxHeight         Int?
    createdAt         DateTime         @default(now())
    user              User?            @relation(fields: [userId], references: [id])
    userId            Int?
    jobs              CompressionJob[]
}

model CompressionJob {
    id                Int                @id @default(autoincrement())
    status            String             @default("PENDING")
    message           String?
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    requester         User               @relation(fields: [requesterId], references: [id])
    requesterId       Int
    inputFile         MediaFile          @relation("JobInput", fields: [inputFileId], references: [id])
    inputFileId       Int
    outputFile        MediaFile?         @relation("JobOutput", fields: [outputFileId], references: [id])
    outputFileId      Int?
    targetSizeBytes   Int?
    targetBitrateKbps Int?
    crf               Int?
    maxWidth          Int?
    maxHeight         Int?
    preserveAudio     Boolean            @default(true)
    preset            CompressionPreset? @relation(fields: [presetId], references: [id])
    presetId          Int?
}