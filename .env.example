# Backend API
PORT=4000
HOST=127.0.0.1
MAX_FILE_SIZE=10737418240

# FFmpeg paths (optional - uses PATH if unset)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe

# Data storage (default: ./data)
# ULTRA_DATA_DIR=./data

# Next.js — set this if uploads fail via proxy (calls API directly from browser)
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# Electron dev
# ULTRA_WEB_URL=http://localhost:3000
